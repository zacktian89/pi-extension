# Ignore everything by default; explicitly allow only non-sensitive sync files.
*

!.gitignore
!README.md
!LICENSE
!package.json
!settings.example.json
!index.ts
!AGENTS.md

!extensions/
!extensions/*.ts

!skills/
!skills/*/
!skills/*/SKILL.md

# Never commit secrets, sessions, trust decisions, or usage history.
auth.json
trust.json
sessions/
codex-usage/
model-usage/
*.bak.*
